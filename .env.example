# Exemple de variables à passer avec --dart-define.
# Ce fichier est documentaire: Flutter ne le charge pas automatiquement.
# Ne mets jamais de vraie clé dans Git.

# Recommandé: faire passer les requêtes IA par le backend Node.
# Android emulator: http://10.0.2.2:3000
# iOS simulator / desktop: http://localhost:3000
MASAKHANE_BACKEND_URL=http://localhost:3000

# Option de test seulement: clé Hugging Face directe côté Flutter.
# Préfère MASAKHANE_BACKEND_URL en production.
# ⚠️ NE JAMAIS commiter une vraie clé. Utilise un placeholder ou --dart-define en local.
HF_TOKEN=hf_YOUR_HF_TOKEN_HERE
